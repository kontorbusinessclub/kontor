# Kontor Business Club - Beispiel-Env. Kopiere nach .env.local und fuelle aus.
# Ohne diese Werte baut und laeuft die App trotzdem (Formulare loggen nur).

# --- Mailversand via Resend (Aufgabe 15) ---
# Resend API-Key. NUR serverseitig.
RESEND_API_KEY=

# Verifizierte Absenderadresse auf der Subdomain kontakt.kontor-businessclub.com
MAIL_FROM=Kontor Business Club <no-reply@kontakt.kontor-businessclub.com>

# Posteingang fuer alle Formular-Benachrichtigungen.
MAIL_TO=info@kontor-businessclub.com

# Optionaler Alt-Fallback fuer den Posteingang (nur falls MAIL_TO fehlt).
KONTOR_INBOX=info@kontor-businessclub.com

# --- SEPA-Lastschrift (Aufgabe 13, Schritt 5) ---
# Erst auf true setzen, wenn die Glaeubiger-Identifikationsnummer vorliegt.
NEXT_PUBLIC_SEPA_ENABLED=false

# --- Supabase (derzeit nicht aktiv genutzt; Mailversand laeuft ueber /api) ---
# Supabase Projekt-URL (EU-Region). Im Browser sichtbar.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public Key. Im Browser sichtbar.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role Key. NUR serverseitig. Umgeht RLS. Niemals committen.
SUPABASE_SERVICE_ROLE_KEY=
